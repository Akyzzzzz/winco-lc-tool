# Optional: override the sheet URLs hard-coded in lib/config.ts.
# Recommended for production deployments so URLs aren't committed to git.
# If left unset, the app falls back to LC_MAPPING_SHEET_URL / COMPANY_DATABASE_SHEET_URL
# defined directly in lib/config.ts.

LC_MAPPING_SHEET_URL=
COMPANY_DATABASE_SHEET_URL=

# ------------------------------------------------------------------------------
# Google Sheets write-back (service account) — required for CRM Status/Notes
# edits made in the dashboard to persist back into the Company sheet.
# Without these, the app still works fully for reading/matching/exporting;
# status edits just won't be saved (the UI says so).
#
# Share BOTH sheets with the service account's email ("client_email" in its
# JSON key): Viewer is enough for LC Mapping, Editor is required for Company.
# ------------------------------------------------------------------------------

# Option 1 (recommended for Vercel): paste the entire downloaded service
# account JSON key as a single-line string.
GOOGLE_SERVICE_ACCOUNT_KEY=

# Option 2: provide the two fields separately instead of GOOGLE_SERVICE_ACCOUNT_KEY.
# The private key's newlines must be escaped as literal "\n".
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional: the tab name inside the Company spreadsheet, if it's not the
# first tab. If unset, the app auto-detects the first tab.
COMPANY_DATABASE_SHEET_TAB=
